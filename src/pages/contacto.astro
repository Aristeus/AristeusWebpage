---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/shared/ContactForm.astro';
import SectionTitle from '../components/shared/SectionTitle.astro';
import ScrollReveal from '../components/animations/ScrollReveal.astro';
---

<BaseLayout title="Contacto" description="Contacta a Aristeus. Solicita tu análisis gratuito o regístrate para acceso temprano a CattleVision.">
  <section class="py-20 md:py-32 bg-bg-primary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ScrollReveal>
        <SectionTitle 
          title="Contacto"
          subtitle="¿Listo para transformar tu operación ganadera? Hablemos."
          align="center"
          class="mb-16"
        />
      </ScrollReveal>
      
      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Contact form -->
        <ScrollReveal animation="slide-right">
          <div class="glass rounded-2xl p-6 md:p-10">
            <h2 class="font-heading text-2xl font-semibold text-text-primary mb-6">
              Solicita tu análisis gratuito
            </h2>
            <ContactForm formName="contact" variant="full" />
          </div>
        </ScrollReveal>
        
        <!-- Contact info + map -->
        <ScrollReveal animation="slide-left" delay={200}>
          <div class="space-y-8">
            <!-- Contact details -->
            <div class="glass rounded-2xl p-6">
              <h3 class="font-heading text-xl font-semibold text-text-primary mb-6">
                Información de contacto
              </h3>
              <div class="space-y-4">
                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 rounded-lg bg-aristeus-navy flex items-center justify-center">
                    <svg class="w-5 h-5 text-aristeus-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                  </div>
                  <div>
                    <p class="text-text-secondary text-sm">Email</p>
                    <p class="text-text-primary">contacto@aristeus.com</p>
                  </div>
                </div>
                
                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 rounded-lg bg-aristeus-navy flex items-center justify-center">
                    <svg class="w-5 h-5 text-aristeus-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                    </svg>
                  </div>
                  <div>
                    <p class="text-text-secondary text-sm">Teléfono / WhatsApp</p>
                    <p class="text-text-primary">+591 XXX XXXX</p>
                  </div>
                </div>
                
                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 rounded-lg bg-aristeus-navy flex items-center justify-center">
                    <svg class="w-5 h-5 text-aristeus-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                  </div>
                  <div>
                    <p class="text-text-secondary text-sm">Ubicación</p>
                    <p class="text-text-primary">Santa Cruz de la Sierra, Bolivia</p>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Map -->
            <div class="glass rounded-2xl p-2 aspect-video">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d121695.4348707857!2d-63.25119685!3d-17.7831675!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x93f1e81c8f139cab%3A0x79763652e3a2978c!2sSanta%20Cruz%20de%20la%20Sierra%2C%20Bolivia!5e0!3m2!1ses!2sus!4v1700000000000!5m2!1ses!2sus"
                width="100%"
                height="100%"
                style="border:0; border-radius: 12px;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                class="rounded-xl"
              ></iframe>
            </div>
            
            <!-- Hours -->
            <div class="glass rounded-2xl p-6">
              <h4 class="font-heading font-semibold text-text-primary mb-3">Horario de atención</h4>
              <p class="text-text-secondary text-sm">
                Lunes a Viernes: 8:00 - 18:00<br/>
                Sábado: 9:00 - 13:00
              </p>
            </div>
          </div>
        </ScrollReveal>
      </div>
    </div>
  </section>
</BaseLayout>
