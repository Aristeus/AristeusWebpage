---
import SectionTitle from '../shared/SectionTitle.astro';
import MetricCard from '../shared/MetricCard.astro';
import ScrollReveal from '../animations/ScrollReveal.astro';
---

<section class="py-20 md:py-32 bg-bg-secondary" id="beneficios">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <ScrollReveal>
      <SectionTitle 
        title="Resultados que impactan tu operación"
        align="center"
        class="mb-16"
      />
    </ScrollReveal>
    
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
      <ScrollReveal animation="fade-up" delay={0}>
        <MetricCard number="40" prefix="+" suffix="%" label="aumento en capacidad de carga" />
      </ScrollReveal>
      <ScrollReveal animation="fade-up" delay={100}>
        <MetricCard number="45" prefix="$" suffix=" USD" label="ahorro por hectárea al año" />
      </ScrollReveal>
      <ScrollReveal animation="fade-up" delay={200}>
        <MetricCard number="5" suffix=" años" label="más de vida útil del pastizal" />
      </ScrollReveal>
      <ScrollReveal animation="fade-up" delay={300}>
        <MetricCard number="15" suffix=" días" label="frecuencia de actualización" />
      </ScrollReveal>
    </div>
    
    <!-- Simple ROI Calculator -->
    <ScrollReveal animation="fade-in">
      <div class="glass rounded-xl p-6 md:p-8 max-w-2xl mx-auto">
        <div class="flex flex-col md:flex-row items-center gap-4">
          <label class="text-text-primary font-medium whitespace-nowrap">
            Ingresa tus hectáreas:
          </label>
          <input 
            type="number" 
            id="hectares-input"
            min="1"
            placeholder="100"
            class="flex-1 w-full px-4 py-3 bg-bg-card border border-border-subtle rounded-lg text-text-primary placeholder-text-secondary focus:outline-none focus:border-aristeus-green transition-smooth"
          />
          <div class="text-center md:text-left">
            <span class="text-text-secondary text-sm">Ahorro anual estimado:</span>
            <div class="font-data text-2xl text-aristeus-green font-semibold" id="savings-result">
              $0
            </div>
          </div>
        </div>
      </div>
    </ScrollReveal>
  </div>
  
  <script>
    const input = document.getElementById('hectares-input') as HTMLInputElement;
    const result = document.getElementById('savings-result');
    
    if (input && result) {
      input.addEventListener('input', () => {
        const hectares = parseInt(input.value) || 0;
        const savings = hectares * 45;
        result.textContent = `$${savings.toLocaleString()}`;
      });
    }
  </script>
</section>
