---
import SectionTitle from '../shared/SectionTitle.astro';
import Button from '../shared/Button.astro';
import ScrollReveal from '../animations/ScrollReveal.astro';
---

<section class="py-20 md:py-32 bg-bg-primary" id="productos">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <ScrollReveal>
      <SectionTitle 
        title="Dos soluciones. Un objetivo: ganadería inteligente."
        align="center"
        class="mb-16"
      />
    </ScrollReveal>
    
    <div class="grid md:grid-cols-2 gap-8">
      <!-- Grass Gauge Card -->
      <ScrollReveal animation="slide-right">
        <div class="glass rounded-2xl p-8 border-l-4 border-aristeus-green hover:shadow-[0_0_30px_rgba(122,185,41,0.2)] transition-smooth h-full flex flex-col">
          <!-- Logo placeholder -->
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 rounded-xl bg-gg-green-dark flex items-center justify-center">
              <span class="text-white text-2xl">🌿</span>
            </div>
            <div>
              <h3 class="font-heading text-2xl font-bold text-gg-green-light">Grass Gauge</h3>
              <p class="text-text-secondary text-sm">Planificación de pastoreo</p>
            </div>
          </div>
          
          <p class="text-text-secondary mb-6 flex-grow">
            Medimos biomasa, determinamos nutrientes y generamos tu plan de rotación optimizado
          </p>
          
          <div class="space-y-3 mb-6">
            <div class="flex items-center gap-3 text-sm">
              <span class="text-gg-green-mid">🛰️</span>
              <span class="text-text-secondary">Imágenes satelitales cada 5-10 días</span>
            </div>
            <div class="flex items-center gap-3 text-sm">
              <span class="text-gg-green-mid">🧠</span>
              <span class="text-text-secondary">ML para estimación de biomasa y nutrientes</span>
            </div>
            <div class="flex items-center gap-3 text-sm">
              <span class="text-gg-green-mid">📋</span>
              <span class="text-text-secondary">Plan de pastoreo listo para ejecutar</span>
            </div>
          </div>
          
          <div class="flex items-center justify-between pt-4 border-t border-border-subtle">
            <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-gg-green-dark/20 text-gg-green-light text-sm font-medium">
              <span class="w-2 h-2 rounded-full bg-gg-green-light animate-pulse"></span>
              DISPONIBLE AHORA
            </span>
            <Button text="Conocer Grass Gauge →" href="/productos#grass-gauge" variant="primary" color="green" size="sm" />
          </div>
        </div>
      </ScrollReveal>
      
      <!-- CattleVision Card -->
      <ScrollReveal animation="slide-left" delay={200}>
        <div class="glass rounded-2xl p-8 border-l-4 border-cv-gold hover:shadow-[0_0_30px_rgba(184,150,62,0.2)] transition-smooth h-full flex flex-col">
          <!-- Logo placeholder -->
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 rounded-xl bg-cv-charcoal flex items-center justify-center border border-cv-gold">
              <span class="text-cv-gold text-2xl">🐂</span>
            </div>
            <div>
              <h3 class="font-heading text-2xl font-bold text-cv-gold">CattleVision</h3>
              <p class="text-text-secondary text-sm">Pesaje con drones</p>
            </div>
          </div>
          
          <p class="text-text-secondary mb-6 flex-grow">
            Estimamos el peso de tu ganado con drones y LiDAR, sin estrés animal ni manejo físico
          </p>
          
          <div class="space-y-3 mb-6">
            <div class="flex items-center gap-3 text-sm">
              <span class="text-cv-gold">🚁</span>
              <span class="text-text-secondary">Drones + LiDAR</span>
            </div>
            <div class="flex items-center gap-3 text-sm">
              <span class="text-cv-gold">👁️</span>
              <span class="text-text-secondary">Visión artificial 3D</span>
            </div>
            <div class="flex items-center gap-3 text-sm">
              <span class="text-cv-gold">⚖️</span>
              <span class="text-text-secondary">Estimación de peso precisa</span>
            </div>
          </div>
          
          <div class="flex items-center justify-between pt-4 border-t border-border-subtle">
            <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-cv-gold/50 text-cv-gold text-sm font-medium">
              <span class="w-2 h-2 rounded-full bg-cv-gold"></span>
              PRÓXIMAMENTE
            </span>
            <Button text="Más información →" href="/productos#cattlevision" variant="outline" color="gold" size="sm" />
          </div>
        </div>
      </ScrollReveal>
    </div>
  </div>
</section>
