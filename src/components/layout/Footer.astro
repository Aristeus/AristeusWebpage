---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;

const footerLinks = {
  products: [
    { label: 'Grass Gauge', href: '/productos#grass-gauge' },
    { label: 'CattleVision', href: '/productos#cattlevision' },
  ],
  company: [
    { label: 'Nosotros', href: '/nosotros' },
    { label: 'Contacto', href: '/contacto' },
  ],
  legal: [
    { label: 'Términos', href: '/terminos' },
    { label: 'Privacidad', href: '/privacidad' },
  ],
};

const socialLinks = [
  { name: 'LinkedIn', href: '#', icon: 'M' },
  { name: 'Twitter', href: '#', icon: 'X' },
  { name: 'Instagram', href: '#', icon: 'I' },
];
---

<footer class={`bg-[#0A0E14] border-t border-border-subtle ${className}`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12">
      <!-- Brand column -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-lg bg-aristeus-navy flex items-center justify-center">
            <span class="font-heading font-bold text-aristeus-green text-xl">A</span>
          </div>
          <span class="font-heading font-semibold text-xl text-text-primary">
            Aristeus
          </span>
        </a>
        <p class="text-text-secondary text-sm mb-4">
          Tecnología para una ganadería sostenible
        </p>
        <!-- Social links -->
        <div class="flex gap-3">
          {socialLinks.map(social => (
            <a 
              href={social.href}
              class="w-9 h-9 rounded-lg bg-bg-card border border-border-subtle flex items-center justify-center text-text-secondary hover:text-aristeus-green hover:border-aristeus-green transition-smooth"
              aria-label={social.name}
            >
              <span class="font-heading text-sm font-bold">{social.icon}</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Products -->
      <div>
        <h4 class="font-heading font-semibold text-text-primary mb-4">
          Productos
        </h4>
        <ul class="space-y-2">
          {footerLinks.products.map(link => (
            <li>
              <a 
                href={link.href}
                class="text-text-secondary hover:text-text-primary text-sm transition-smooth"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="font-heading font-semibold text-text-primary mb-4">
          Empresa
        </h4>
        <ul class="space-y-2">
          {footerLinks.company.map(link => (
            <li>
              <a 
                href={link.href}
                class="text-text-secondary hover:text-text-primary text-sm transition-smooth"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="font-heading font-semibold text-text-primary mb-4">
          Legal
        </h4>
        <ul class="space-y-2">
          {footerLinks.legal.map(link => (
            <li>
              <a 
                href={link.href}
                class="text-text-secondary hover:text-text-primary text-sm transition-smooth"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-border-subtle flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-text-secondary text-sm text-center md:text-left">
        © 2025 Aristeus. Tecnología para una ganadería sostenible.
      </p>
      <p class="text-text-secondary text-sm flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        Santa Cruz de la Sierra, Bolivia
      </p>
    </div>
  </div>
</footer>
