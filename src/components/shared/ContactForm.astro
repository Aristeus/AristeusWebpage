---
interface Props {
  formName?: string;
  variant?: 'compact' | 'full';
  class?: string;
}

const { formName = 'contact', variant = 'full', class: className = '' } = Astro.props;

const isFull = variant === 'full';
---

<form 
  name={formName} 
  method="POST" 
  data-netlify="true"
  netlify-honeypot="bot-field"
  class={`flex flex-col gap-4 ${className}`}
>
  <p class="hidden">
    <label>
      Don't fill this out if you're human: <input name="bot-field" />
    </label>
  </p>
  
  <input type="hidden" name="form-name" value={formName} />
  
  <div class={`grid gap-4 ${isFull ? 'md:grid-cols-2' : 'grid-cols-1'}`}>
    <input 
      type="text" 
      name="name" 
      placeholder="Nombre completo"
      required
      class="w-full px-4 py-3 bg-bg-card border border-border-subtle rounded-lg text-text-primary placeholder-text-secondary focus:outline-none focus:border-aristeus-green transition-smooth"
    />
    
    <input 
      type="email" 
      name="email" 
      placeholder="Email"
      required
      class="w-full px-4 py-3 bg-bg-card border border-border-subtle rounded-lg text-text-primary placeholder-text-secondary focus:outline-none focus:border-aristeus-green transition-smooth"
    />
  </div>
  
  {isFull && (
    <div class="grid gap-4 md:grid-cols-2">
      <input 
        type="tel" 
        name="phone" 
        placeholder="Teléfono / WhatsApp"
        class="w-full px-4 py-3 bg-bg-card border border-border-subtle rounded-lg text-text-primary placeholder-text-secondary focus:outline-none focus:border-aristeus-green transition-smooth"
      />
      
      <input 
        type="text" 
        name="property" 
        placeholder="Nombre de la propiedad"
        class="w-full px-4 py-3 bg-bg-card border border-border-subtle rounded-lg text-text-primary placeholder-text-secondary focus:outline-none focus:border-aristeus-green transition-smooth"
      />
    </div>
  )}
  
  {isFull && (
    <div class="grid gap-4 md:grid-cols-2">
      <input 
        type="number" 
        name="hectares" 
        placeholder="Hectáreas aproximadas"
        min="1"
        class="w-full px-4 py-3 bg-bg-card border border-border-subtle rounded-lg text-text-primary placeholder-text-secondary focus:outline-none focus:border-aristeus-green transition-smooth"
      />
      
      <select 
        name="region"
        class="w-full px-4 py-3 bg-bg-card border border-border-subtle rounded-lg text-text-primary focus:outline-none focus:border-aristeus-green transition-smooth appearance-none cursor-pointer"
      >
        <option value="">Departamento/Región</option>
        <option value="santa-cruz">Santa Cruz</option>
        <option value="beni">Beni</option>
        <option value="pando">Pando</option>
        <option value="otro">Otro</option>
      </select>
    </div>
  )}
  
  {isFull && (
    <textarea 
      name="message" 
      placeholder="Mensaje (opcional)"
      rows={4}
      class="w-full px-4 py-3 bg-bg-card border border-border-subtle rounded-lg text-text-primary placeholder-text-secondary focus:outline-none focus:border-aristeus-green transition-smooth resize-none"
    ></textarea>
  )}
  
  <label class="flex items-center gap-3 cursor-pointer">
    <input 
      type="checkbox" 
      name="consent" 
      required
      class="w-5 h-5 rounded border-border-subtle bg-bg-card text-aristeus-green focus:ring-aristeus-green focus:ring-offset-bg-primary"
    />
    <span class="text-text-secondary text-sm">
      Acepto ser contactado por Aristeus
    </span>
  </label>
  
  <button 
    type="submit"
    class="w-full md:w-auto self-center px-8 py-4 bg-aristeus-green text-bg-primary font-semibold rounded-lg hover:brightness-110 transition-smooth"
  >
    Solicitar Análisis Gratuito
  </button>
</form>
